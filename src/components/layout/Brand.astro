---
import site from "@/config/site";
import { Image } from "astro:assets";
---

<a
  href="/home"
  aria-label={`${site.meta.title} home`}
  class="group mb-6 flex items-center gap-4 rounded-2xl transition-colors hover:text-primary focus-visible:ring-2 focus-visible:ring-primary/30 focus-visible:outline-none md:mb-10 md:flex-col md:items-start md:gap-0"
>
  <div class="flex items-center justify-center">
    <Image
      loading={"eager"}
      src={site.meta.logo}
      alt={"Site logo"}
      width={64}
      height={64}
      class="h-12 w-12 object-contain transition-[filter] duration-300 md:h-16 md:w-16"
    />
  </div>
  <div class="md:mt-8">
    <h1
      data-pagefind-ignore
      class="text-[1.35rem] font-black tracking-tight text-foreground transition-colors group-hover:text-primary md:text-[1.35rem]"
    >
      {site.meta.title}
    </h1>
    <p class="mt-2 hidden text-xs text-muted-foreground/70 md:block">
      {site.meta.description}
    </p>
  </div>
</a>
